{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Tauri",
  "version": "0.2.1",
  "identifier": "com.sacheth.claude-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Tauri",
        "width": 1000,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFDQUUxRUY2OTBDRUQ4MTAKUldRUTJNNlE5aDZ1ckZaOCsxYldVd2tZT3dZNzJmUktXanNRek84YXNLdGRnaDdxaFFYUjB1NzkK",
      "endpoints": [
        "https://github.com/ksacheth/claude-code-acp/releases/latest/download/latest.json"
      ]
    }
  }
}
